# Ignore editor specific config folders/files
/.vscode

# Ignore compilation result directories
/build
/output

# Ignore generated files in the libdragon FS
/filesystem/Firple-Bold.font64
/filesystem/FiraMonoBold.font64
/filesystem/*.wav64
/filesystem/*.sprite

# Ignore external development tools
/toolchain/
/tools/*
!/tools/sc64/
/tools/sc64/*
!/tools/sc64/metadata_fill_from_thegamesdb.py
!/tools/sc64/metadata_fill_from_region_siblings.py

# Ignore any N64 ROM
**/*.n64
**/*.v64
**/*.z64

# Ignore exe files
*.exe

# Ignore macOS filesystem cruft
.DS_Store

# Ignore local API credentials
.env
.env.local

reports
